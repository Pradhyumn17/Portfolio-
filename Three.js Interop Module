import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js';

let scene, camera, renderer, raycaster, mouse;
let dotNetRef; // Reference to the C# ThreeJsService
let interactableObjects = [];

// Touch state for pinch-to-zoom and swipe
let touchPinchDistance = 0;
let isDragging = false;
let previousMousePosition = { x: 0, y: 0 };

export function initThreeJs(canvasId, csharpRef) {
    dotNetRef = csharpRef;
    const canvas = document.getElementById(canvasId);

    // 1. Scene Setup
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x111111);

    // 2. Camera Setup
    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 5;

    // 3. Renderer Setup
    renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // Optimize for high-DPI

    // 4. Lighting & Objects (Sample Cube for portfolio interaction)
    const light = new THREE.DirectionalLight(0xffffff, 1);
    light.position.set(1, 1, 2);
    scene.add(light);
    scene.add(new THREE.AmbientLight(0x404040));

    const geometry = new THREE.BoxGeometry(2, 2, 2);
    const material = new THREE.MeshStandardMaterial({ color: 0x00ffcc });
    const cube = new THREE.Mesh(geometry, material);
    cube.userData = { id: "portfolio_project_1" }; // ID to send to C#
    scene.add(cube);
    interactableObjects.push(cube);

    // 5. Interaction Utilities
    raycaster = new THREE.Raycaster();
    mouse = new THREE.Vector2();

    // 6. Event Listeners
    setupEventListeners(canvas);

    // 7. Render Loop
    animate();
}

export function updateCamera(width, height, fov) {
    if (camera && renderer) {
        camera.aspect = width / height;
        camera.fov = fov;
        camera.updateProjectionMatrix();
        renderer.setSize(width, height);
    }
}

function setupEventListeners(canvas) {
    // Mouse Events
    canvas.addEventListener('pointerdown', onPointerDown);
    canvas.addEventListener('pointermove', onPointerMove);
    canvas.addEventListener('pointerup', onPointerUp);
    
    // Touch Events (Mobile)
    canvas.addEventListener('touchstart', onTouchStart, { passive: false });
    canvas.addEventListener('touchmove', onTouchMove, { passive: false });
}

function onPointerDown(event) {
    isDragging = true;
    previousMousePosition = { x: event.clientX, y: event.clientY };
    
    // Raycasting for clicks
    mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
    mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
    
    raycaster.setFromCamera(mouse, camera);
    const intersects = raycaster.intersectObjects(interactableObjects);
    
    if (intersects.length > 0) {
        // Send click event to C# Blazor
        dotNetRef.invokeMethodAsync('HandleObjectClick', intersects[0].object.userData.id);
    }
}

function onPointerMove(event) {
    if (isDragging) {
        // Handle Drag/Swipe to rotate scene
        const deltaMove = {
            x: event.clientX - previousMousePosition.x,
            y: event.clientY - previousMousePosition.y
        };

        scene.rotation.y += deltaMove.x * 0.01;
        scene.rotation.x += deltaMove.y * 0.01;

        previousMousePosition = { x: event.clientX, y: event.clientY };
    } else {
        // Handle Hover effect (cursor change)
        mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
        mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
        raycaster.setFromCamera(mouse, camera);
        const intersects = raycaster.intersectObjects(interactableObjects);
        document.body.style.cursor = intersects.length > 0 ? 'pointer' : 'default';
    }
}

function onPointerUp() {
    isDragging = false;
}

function onTouchStart(event) {
    if (event.touches.length === 2) {
        // Setup pinch-to-zoom initial distance
        touchPinchDistance = Math.hypot(
            event.touches[0].clientX - event.touches[1].clientX,
            event.touches[0].clientY - event.touches[1].clientY
        );
    }
}

function onTouchMove(event) {
    event.preventDefault(); // Prevent standard browser scroll
    if (event.touches.length === 2) {
        // Handle Pinch-to-Zoom
        const currentDistance = Math.hypot(
            event.touches[0].clientX - event.touches[1].clientX,
            event.touches[0].clientY - event.touches[1].clientY
        );
        
        const zoomDelta = (touchPinchDistance - currentDistance) * 0.05;
        camera.position.z += zoomDelta;
        
        // Clamp zoom
        camera.position.z = Math.max(2, Math.min(camera.position.z, 15));
        touchPinchDistance = currentDistance;
        
        // Notify C# of zoom change
        dotNetRef.invokeMethodAsync('HandleZoom', camera.position.z);
    }
}

function animate() {
    requestAnimationFrame(animate);
    renderer.render(scene, camera);
}
